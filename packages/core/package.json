{
  "name": "@augerjs/core",
  "version": "0.3.0",
  "description": "Core indexing engine for auger — parses TypeScript/Ruby source files into a SQLite symbol index",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wjin17/augerjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "mkdir -p dist/db && cp src/db/schema.sql dist/db/",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chokidar": "^3.6.0",
    "ts-morph": "^23.0.0",
    "tree-sitter": "^0.21.0",
    "tree-sitter-ruby": "^0.21.0",
    "yaml": "^2.5.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0"
  }
}
