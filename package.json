{
  "name": "@augerjs/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '@augerjs/core' build && bun run --filter '@augerjs/mcp' build && bun run --filter '@augerjs/cli' build",
    "bench": "vitest bench --run",
    "bench:compare": "vitest run --reporter verbose packages/core/src/bench-compare.test.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "eslint packages/*/src",
    "format": "prettier --write packages/*/src",
    "format:check": "prettier --check packages/*/src",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "eslint": "9",
    "prettier": "^3.8.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.0.0"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "tree-sitter-ruby"
  ]
}
