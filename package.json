{
  "name": "@augerjs/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '@augerjs/core' build && bun run --filter '@augerjs/mcp' build && bun run --filter '@augerjs/cli' build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0"
  },
  "trustedDependencies": [
    "tree-sitter-ruby"
  ]
}
